{% comment %}
  AfterSol Product Cards Section
  Displays product options with real Shopify add-to-cart functionality.
  Each card can link to an actual Shopify product for direct add-to-cart.
{% endcomment %}

<section class="aftersol-section aftersol-product-cards" id="order">
  <div class="aftersol-container">
    <p class="aftersol-section-subtitle">{{ section.settings.subtitle | default: 'Choose Your Kit' }}</p>
    <h2 class="aftersol-section-title">{{ section.settings.title | default: 'Pick the Right Size for You' }}</h2>

    <div class="aftersol-cards-grid">
      {% for block in section.blocks %}
        <div class="aftersol-product-card {% if block.settings.featured %}aftersol-product-card--featured{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.badge != blank %}
            <span class="aftersol-product-badge">{{ block.settings.badge }}</span>
          {% endif %}
          <h3 class="aftersol-product-name">{{ block.settings.name }}</h3>
          <p class="aftersol-product-contents">{{ block.settings.contents }}</p>
          <p class="aftersol-product-price">{{ block.settings.price }}</p>
          <p class="aftersol-product-per-treatment">{{ block.settings.per_treatment }}</p>
          {% if block.settings.original_price != blank %}
            <p class="aftersol-product-savings">
              <s>{{ block.settings.original_price }}</s> — You save {{ block.settings.savings }}
            </p>
          {% endif %}

          {% if block.settings.product != blank %}
            {%- assign product_ref = block.settings.product -%}
            {%- assign variant = product_ref.selected_or_first_available_variant -%}
            <form method="post" action="/cart/add" class="aftersol-add-to-cart-form">
              <input type="hidden" name="id" value="{{ variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button
                type="submit"
                class="aftersol-btn-primary aftersol-product-btn"
                data-add-to-cart
                {% unless variant.available %}disabled{% endunless %}
              >
                {% if variant.available %}
                  {{ block.settings.button_text | default: 'Add to Cart' }}
                {% else %}
                  Sold Out
                {% endif %}
              </button>
            </form>
          {% else %}
            <a href="{{ block.settings.product_link | default: '#order' }}" class="aftersol-btn-primary aftersol-product-btn">
              {{ block.settings.button_text | default: 'Add to Cart' }}
            </a>
          {% endif %}
        </div>
      {% else %}
        <!-- Default cards shown when no blocks are configured in the theme editor -->
        <div class="aftersol-product-card">
          <h3 class="aftersol-product-name">2-Pack — Try It</h3>
          <p class="aftersol-product-contents">1 Hydrogel + 1 Recovery Sheet</p>
          <p class="aftersol-product-price">$10</p>
          <p class="aftersol-product-per-treatment">$10.00 / treatment</p>
          <a href="/collections/all" class="aftersol-btn-primary aftersol-product-btn">Shop Now</a>
        </div>
        <div class="aftersol-product-card">
          <h3 class="aftersol-product-name">4-Pack — Weekend Pack</h3>
          <p class="aftersol-product-contents">2 Hydrogel + 2 Recovery Sheets</p>
          <p class="aftersol-product-price">$25</p>
          <p class="aftersol-product-per-treatment">$12.50 / treatment</p>
          <a href="/collections/all" class="aftersol-btn-primary aftersol-product-btn">Shop Now</a>
        </div>
        <div class="aftersol-product-card aftersol-product-card--featured">
          <span class="aftersol-product-badge">Best Value</span>
          <h3 class="aftersol-product-name">8-Pack — Full Kit</h3>
          <p class="aftersol-product-contents">4 Hydrogel + 4 Recovery Sheets</p>
          <p class="aftersol-product-price">$35</p>
          <p class="aftersol-product-per-treatment">$4.38 / treatment</p>
          <p class="aftersol-product-savings"><s>$44</s> — You save $9</p>
          <a href="/collections/all" class="aftersol-btn-primary aftersol-product-btn">Shop Now</a>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_trust_signals %}
    <div class="aftersol-trust-signals" style="margin-top: 32px;">
      <span class="aftersol-trust-item">
        <span class="aftersol-trust-icon">&#10003;</span> Free Shipping
      </span>
      <span class="aftersol-trust-item">
        <span class="aftersol-trust-icon">&#10003;</span> 100% Money-Back Guarantee
      </span>
      <span class="aftersol-trust-item">
        <span class="aftersol-trust-icon">&#128274;</span> Secure Checkout
      </span>
    </div>
    {% endif %}
  </div>
</section>

<!-- AJAX Add to Cart -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.aftersol-add-to-cart-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('[data-add-to-cart]');
        var originalText = btn.textContent.trim();
        btn.textContent = 'Adding...';
        btn.disabled = true;

        var formData = new FormData(form);
        var data = {};
        formData.forEach(function(value, key) { data[key] = value; });

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: parseInt(data.id), quantity: parseInt(data.quantity) }] })
        })
        .then(function(response) {
          if (!response.ok) throw new Error('Add to cart failed');
          return response.json();
        })
        .then(function() {
          btn.textContent = 'Added!';
          btn.style.background = '#22964f';

          // Update cart count in header
          fetch('/cart.js')
            .then(function(r) { return r.json(); })
            .then(function(cart) {
              var cartCounts = document.querySelectorAll('.cart-count-bubble span[aria-hidden]');
              cartCounts.forEach(function(el) { el.textContent = cart.item_count; });
              var cartBubble = document.querySelector('.cart-count-bubble');
              if (cartBubble) cartBubble.style.display = '';
            });

          setTimeout(function() {
            btn.textContent = originalText;
            btn.style.background = '';
            btn.disabled = false;
          }, 2000);
        })
        .catch(function() {
          btn.textContent = 'Error — Try Again';
          btn.style.background = '#c53030';
          setTimeout(function() {
            btn.textContent = originalText;
            btn.style.background = '';
            btn.disabled = false;
          }, 2000);
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "AfterSol Product Cards",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Choose Your Kit"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pick the Right Size for You"
    },
    {
      "type": "checkbox",
      "id": "show_trust_signals",
      "label": "Show Trust Signals",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Shopify Product",
          "info": "Select the actual product to enable real add-to-cart. Leave blank to use the fallback link below."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Display Name",
          "default": "AfterSol Kit"
        },
        {
          "type": "text",
          "id": "contents",
          "label": "Kit Contents",
          "default": "1 Hydrogel + 1 Recovery Sheet"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Display Price",
          "default": "$10"
        },
        {
          "type": "text",
          "id": "per_treatment",
          "label": "Per Treatment Price",
          "default": "$10.00 / treatment"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price (leave blank to hide)"
        },
        {
          "type": "text",
          "id": "savings",
          "label": "Savings Amount (leave blank to hide)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text (leave blank to hide)"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured Card (highlighted border)",
          "default": false
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Add to Cart"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Fallback Link (used when no product selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AfterSol Product Cards",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "name": "2-Pack — Try It",
            "contents": "1 Hydrogel + 1 Recovery Sheet",
            "price": "$10",
            "per_treatment": "$10.00 / treatment",
            "button_text": "Add to Cart"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "name": "4-Pack — Weekend Pack",
            "contents": "2 Hydrogel + 2 Recovery Sheets",
            "price": "$25",
            "per_treatment": "$12.50 / treatment",
            "button_text": "Add to Cart"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "name": "8-Pack — Full Kit",
            "contents": "4 Hydrogel + 4 Recovery Sheets",
            "price": "$35",
            "per_treatment": "$4.38 / treatment",
            "original_price": "$44",
            "savings": "$9",
            "badge": "Best Value",
            "featured": true,
            "button_text": "Add to Cart"
          }
        }
      ]
    }
  ]
}
{% endschema %}
