{% comment %}
  AfterSol How It Works Section - Atelier Theme
  Clean step-by-step process visualization
{% endcomment %}

<section class="aftersol-steps section-{{ section.id }}">
  <div class="page-width">
    <header class="aftersol-steps__header section-header">
      {% if section.settings.eyebrow != blank %}
        <p class="caption">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="h2">{{ section.settings.heading | default: "Two Steps. One Night. Done." }}</h2>
    </header>

    <div class="aftersol-steps__grid">
      {% for block in section.blocks %}
        <div class="aftersol-steps__item" {{ block.shopify_attributes }}>
          <span class="aftersol-steps__number caption">Step {{ forloop.index }}</span>

          {% if block.settings.image != blank %}
            <div class="aftersol-steps__media">
              {{ block.settings.image | image_url: width: 600 | image_tag: class: 'aftersol-steps__image', loading: 'lazy' }}
            </div>
          {% endif %}

          <h3 class="h4">{{ block.settings.title }}</h3>
          <p class="body">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_cta %}
      <div class="aftersol-steps__cta">
        <a href="{{ section.settings.button_link | default: '/products/aftersol-kit' }}" class="button button--primary">
          {{ section.settings.button_text | default: 'Get Your Kit — $44' }}
        </a>
        {% if section.settings.show_availability %}
          <p class="caption aftersol-steps__availability">
            <span class="availability-dot"></span>
            {{ section.settings.availability_text | default: 'In Stock — Ships within 24-48 hours' }}
          </p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .aftersol-steps {
    padding: var(--spacing-section-vertical) 0;
  }

  .aftersol-steps__header {
    text-align: center;
    margin-bottom: var(--spacing-12);
  }

  .aftersol-steps__header .caption {
    color: var(--color-foreground-secondary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--spacing-4);
  }

  .aftersol-steps__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-10);
  }

  @media screen and (min-width: 750px) {
    .aftersol-steps__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .aftersol-steps__item {
    text-align: center;
  }

  .aftersol-steps__number {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-foreground-secondary);
    margin-bottom: var(--spacing-4);
  }

  .aftersol-steps__media {
    margin-bottom: var(--spacing-6);
    overflow: hidden;
    border-radius: var(--border-radius);
  }

  .aftersol-steps__image {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .aftersol-steps__item .h4 {
    margin-bottom: var(--spacing-3);
  }

  .aftersol-steps__item .body {
    color: var(--color-foreground-secondary);
    max-width: 36ch;
    margin: 0 auto;
  }

  .aftersol-steps__cta {
    text-align: center;
    margin-top: var(--spacing-12);
  }

  .aftersol-steps__availability {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    margin-top: var(--spacing-4);
    color: var(--color-foreground-secondary);
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
  }
</style>

{% schema %}
{
  "name": "AfterSol How It Works",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Two Steps. One Night. Done."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get Your Kit — $44"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_availability",
      "label": "Show availability",
      "default": true
    },
    {
      "type": "text",
      "id": "availability_text",
      "label": "Availability text",
      "default": "In Stock — Ships within 24-48 hours"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Step description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AfterSol How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Cooling Hydrogel Sheet",
            "description": "Apply to burned skin. Intense cooling starts immediately. Pain drops fast. Remove after 30 minutes."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Recovery Sheet (Overnight)",
            "description": "Apply before bed. Sustained cooling keeps you comfortable all night. Wake up recovered, not wrecked."
          }
        }
      ]
    }
  ]
}
{% endschema %}
