{% comment %}
  AfterSol Testimonials Section - Atelier Theme
  Elegant testimonial carousel with clean typography
{% endcomment %}

<section class="aftersol-testimonials section-{{ section.id }}">
  <div class="page-width">
    <header class="aftersol-testimonials__header section-header">
      {% if section.settings.eyebrow != blank %}
        <p class="caption">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="h2">{{ section.settings.heading | default: "What People Are Saying" }}</h2>
    </header>

    <div class="aftersol-testimonials__grid">
      {% for block in section.blocks %}
        <div class="aftersol-testimonials__item" {{ block.shopify_attributes }}>
          <div class="aftersol-testimonials__stars">
            {% for i in (1..5) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </div>

          <blockquote class="aftersol-testimonials__quote body-large">
            "{{ block.settings.quote }}"
          </blockquote>

          <footer class="aftersol-testimonials__author">
            <span class="aftersol-testimonials__name">{{ block.settings.author }}</span>
            {% if block.settings.verified %}
              <span class="aftersol-testimonials__verified caption">Verified Purchase</span>
            {% endif %}
          </footer>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .aftersol-testimonials {
    padding: var(--spacing-section-vertical) 0;
    background: {{ section.settings.background_color | default: '#FFFAF5' }};
  }

  .aftersol-testimonials__header {
    text-align: center;
    margin-bottom: var(--spacing-12);
  }

  .aftersol-testimonials__header .caption {
    color: var(--color-foreground-secondary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--spacing-4);
  }

  .aftersol-testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
  }

  @media screen and (min-width: 750px) {
    .aftersol-testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .aftersol-testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .aftersol-testimonials__item {
    padding: var(--spacing-8);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
  }

  .aftersol-testimonials__stars {
    display: flex;
    gap: 2px;
    color: #f59e0b;
    margin-bottom: var(--spacing-4);
  }

  .aftersol-testimonials__quote {
    margin-bottom: var(--spacing-6);
    font-style: italic;
  }

  .aftersol-testimonials__author {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .aftersol-testimonials__name {
    font-weight: 500;
  }

  .aftersol-testimonials__verified {
    color: var(--color-foreground-secondary);
  }
</style>

{% schema %}
{
  "name": "AfterSol Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What People Are Saying"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFAF5"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This product changed my life."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Customer Name"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified purchase",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AfterSol Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "I got absolutely torched in Cabo. This kit saved my trip. Slept through the night for the first time in years after a bad burn.",
            "author": "Marcus T.",
            "verified": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "My husband is stubborn about sunscreen. This kit is now our vacation essential. The overnight sheet is incredible.",
            "author": "Jennifer R.",
            "verified": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Way better than aloe. The cooling actually lasts. Woke up feeling human again after a brutal beach day.",
            "author": "David K.",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
