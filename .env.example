# Kalshi API credentials
# Get these from: https://kalshi.com/account/profile → API Keys
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY=/path/to/your/kalshi_private_key.pem

# Environment: set KALSHI_DEMO=true to use the demo (paper trading) environment
KALSHI_DEMO=false

# Dry-run: set true to log order intent but never submit real orders
KALSHI_DRY_RUN=false
